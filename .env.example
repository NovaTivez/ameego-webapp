# Server-only OpenAI API key. Required for resume extraction, personalized
# question generation, and STAR feedback evaluation. Never expose it with a
# NEXT_PUBLIC_ prefix. Without a key, question generation offers a clearly
# labeled general (non-AI) fallback, but STAR evaluation returns 503 and
# cannot run.
OPENAI_API_KEY=

# Optional. Defaults to gpt-5.6 when unset.
OPENAI_MODEL=gpt-5.6
