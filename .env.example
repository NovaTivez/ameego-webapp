# Server-only Groq API key. Required for resume extraction, personalized
# question generation, and STAR feedback evaluation. Never expose it with a
# NEXT_PUBLIC_ prefix. Without a key, question generation offers a clearly
# labeled general (non-AI) fallback, but STAR evaluation returns 503 and
# cannot run.
# Get a key at https://console.groq.com
GROQ_API_KEY=

# Optional. Defaults to the cheapest Llama on Groq when unset.
GROQ_MODEL=llama-3.1-8b-instant
